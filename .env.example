# ============================================================================
# Springware CMS — 환경 변수 설정
# ============================================================================
#
# 로컬 개발 환경 세팅 순서:
#
#   1. 이 파일을 복사하여 .env 파일 생성:
#        cp .env.example .env
#
#   2. Node.js 패키지 설치:
#        npm install
#
#   3. Playwright 브라우저 바이너리 설치 (E2E 테스트용, 최초 1회):
#        npx playwright install
#        - Chromium·Firefox·WebKit 바이너리를 ~/.cache/ms-playwright/ 에 다운로드
#        - npm install과 별도 실행 필요 (git 미추적 파일)
#        - E2E 테스트 실행 안 할 경우 생략 가능
#
#   4. Oracle Instant Client 설치 필요:
#        - 다운로드: https://www.oracle.com/database/technologies/instant-client/downloads.html
#        - Windows: Basic 패키지 압축 해제 후 PATH에 추가
#        - Mac: Homebrew로 설치 가능 (brew install instantclient-basic)
#        - oracledb 패키지가 Thick 모드로 동작하므로 반드시 필요
#
#   5. 아래 Oracle DB 계정 정보 입력
#
#   6. 개발 서버 실행:
#        npm run dev
#
# ── .env 로드 참고 ──
#   - npm run dev (Next.js): .env를 자동으로 로드함
#   - 단독 스크립트 (npx tsx *.ts 등): .env를 자동 로드하지 않음
#     → 스크립트 상단에 import 'dotenv/config'; 추가 필요
#     → 또는 실행 시: npx dotenv -- npx tsx 스크립트.ts
#
# ============================================================================

# ── AI 프로바이더 (선택) ──
# 에디터 AI 코드 생성/채팅 기능에 필요. 없으면 AI 기능만 비활성화됨.
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# AI 이미지 생성 (fal.ai)
FAL_API_KEY=

# Google GenAI (웹 버전)
GEMINI_API_KEY=

# ── 파일 업로드 ──
# 에디터에서 업로드한 파일이 저장되는 경로. 기본값 그대로 사용 가능.
UPLOAD_PATH=public/uploads/
UPLOAD_URL=uploads/

# ── 에셋 저장소 ──
# 업로드된 에셋 파일이 저장되는 디렉토리와 클라이언트 접근 URL.
# 로컬 개발: public/uploads → /uploads (Next.js 정적 서빙)
# 운영 배포: Docker Volume + 서브도메인 (예: /data/images → https://static.bank.com)
ASSET_UPLOAD_DIR=public/uploads
ASSET_BASE_URL=/uploads

# ── Oracle DB (필수) ──
# 페이지 저장/로드, 금융 컴포넌트 등 모든 데이터를 DB에서 관리.
# Oracle Instant Client가 설치되어 있어야 함 (Thick 모드).
# 계정 정보는 팀 내부 채널로 공유.
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE=XE
ORACLE_SCHEMA=

# ── 보안 ──
# JWT 서명 키 — 로그인 토큰 발급·검증에 사용. 충분히 길고 랜덤한 문자열로 설정.
# 예: openssl rand -hex 32
JWT_SECRET=

# 배포 수신 토큰 — CMS 서버와 운영 서버가 동일한 값을 공유해야 함.
# /api/deploy/receive 호출 시 x-deploy-token 헤더로 전달.
# 예: openssl rand -hex 32
DEPLOY_SECRET=

# ── 스케줄러 (만료 처리) ──
# 만료 일괄 처리 API(/api/scheduler/expire) 호출 시 인증 토큰.
# 임의의 문자열을 설정하고, 호출 시 x-scheduler-token 헤더에 동일 값 전달.
# 예: SCHEDULER_SECRET=springware-expire-2026
SCHEDULER_SECRET=

# ── 브랜드 테마 ──
# 금융 컴포넌트 삽입 시 적용할 브랜드 색상 팔레트.
# 지원 값: IBK, HANA, KB, IM (src/data/brand-themes.ts 참조)
# 미설정 시 컴포넌트 기본 색상(#0046A4 등 IBK 하드코딩) 그대로 사용.
BANK_BRAND=IBK

# ── 인증 우회 (테스트용) ─────────────────────────────────────────────────────
# true: admin 로그인 없이 CMS 접근 허용 (개발·테스트 환경 전용)
# 운영 시 반드시 제거하거나 false로 설정
# AUTH_BYPASS=true

# ── git 자동 커밋·푸시 ──
# 페이지 저장 시 HTML 파일을 git에 자동으로 커밋·푸시한다.
# 운영 서버에서만 true로 설정. 로컬 개발 환경에서는 false(기본).
# git CLI와 원격 저장소 push 권한(SSH 키 또는 토큰)이 사전 설정되어 있어야 함.
GIT_AUTO_COMMIT=false
GIT_USER_NAME=Springware CMS
GIT_USER_EMAIL=cms@springware.local
GIT_BRANCH=main

# ── CMS 서버 URL (배포용) ──
# 배포된 HTML에서 에셋(이미지, CSS, JS)을 CMS 서버에서 로드하기 위한 기본 URL.
# 운영 서버 분리 시 실제 CMS 도메인으로 변경.
CMS_BASE_URL=http://localhost:3000

