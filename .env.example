# ── AI 프로바이더 ──
OPENROUTER_API_KEY=
OPENAI_API_KEY=
FAL_API_KEY=
GEMINI_API_KEY=

# ── 파일 업로드 ──
UPLOAD_PATH=public/uploads/
UPLOAD_URL=uploads/

# ── DB 전환 플래그 ──
# true: Oracle DB 기반 저장/로드, false: 파일 기반 폴백 (data/*.json)
DB_ENABLED=false

# ── Oracle DB ──
# 외부 Oracle XE 서버에 접속 (계정 정보는 팀 내부 채널로 공유)
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_HOST=neobns.com
ORACLE_PORT=11521
ORACLE_SERVICE=XE
ORACLE_SCHEMA=D_SPIDERLINK
