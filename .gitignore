# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── 의존성 ──
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js 빌드 산출물 ──
/.next/
/out/
/build

# ── 환경변수 (API 키 포함) ──
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
.env.prod
!.env.prod.example

# ── 사용자 업로드 파일 ──
# 런타임에 생성되는 파일 — 기본 제외, 공유 필요한 폴더만 예외 처리
/public/uploads/*
!/public/uploads/pages/

# ── 배포 저장소 (승인 완료 이미지) ──
# Spider Admin 승인 시 복사되는 파일 — 런타임 데이터
/public/deployed/

# ── 저장된 콘텐츠 데이터 ──
# 에디터에서 저장된 페이지 데이터 (운영 환경마다 다름)
/data/index.json
/data/ibk.json

# ── Claude Code 설정 ──
.claude/settings.json
.claude/settings.local.json

# ── TypeScript ──
*.tsbuildinfo
next-env.d.ts

# ── 테스트 커버리지 ──
/coverage

# ── Playwright ──
/playwright-report/
/test-results/
/e2e/snapshots/

# ── 배포 ──
.vercel

# ── Oracle Docker 볼륨 ──
oracle-data/

# ── OS / 에디터 잡파일 ──
.DS_Store
Thumbs.db
*.pem

# ── 디버그 로그 ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

#임시 페이지 파일 
/data