# ============================================================================
# .env.prod — 운영 환경 변수
# ============================================================================
#
# 사용법:
#   1. 이 파일을 복사하여 .env.prod 생성:
#        cp .env.prod.example .env.prod
#
#   2. 모든 항목에 실제 값 입력 후 NHN Cloud 인스턴스에 배치:
#        scp .env.prod ubuntu@<인스턴스IP>:~/springware-cms/.env.prod
#
#   ※ .env.prod는 .gitignore에 포함되어 있어 git에 절대 커밋되지 않습니다.
#
# ============================================================================

# ── Oracle DB (개발 DB 공용) ────────────────────────────────────────────────
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_HOST=                # 개발 DB 서버 IP 또는 도메인
ORACLE_PORT=1521
ORACLE_SERVICE=XE
ORACLE_SCHEMA=

# ── 보안 ────────────────────────────────────────────────────────────────────
# 생성: openssl rand -hex 32
JWT_SECRET=
DEPLOY_SECRET=              # CMS 컨테이너와 운영 컨테이너 반드시 동일한 값 사용
SCHEDULER_SECRET=

# ── 서버 운영 모드 ─────────────────────────────────────────────────────────────
# cms: :3000 관리자 컨테이너 / operation: :3001 제작자 컨테이너
SERVER_MODE=cms

# ── CMS 서버 공개 URL ────────────────────────────────────────────────────────
# 배포된 HTML 내부에서 에셋(JS, CSS, 이미지)을 참조하는 기준 URL
# Nginx를 통해 외부에 노출되는 CMS 관리자 주소로 설정
CMS_BASE_URL=http://<NHN_인스턴스_공인IP>

# ── AI 프로바이더 (선택) ────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENAI_API_KEY=
FAL_API_KEY=
GEMINI_API_KEY=

# ── 에셋 저장소 ─────────────────────────────────────────────────────────────
ASSET_UPLOAD_DIR=/app/public/uploads
ASSET_BASE_URL=/static


# ── 인증 우회 (테스트용) ─────────────────────────────────────────────────────
# true: admin 로그인 없이 CMS 접근 허용 (개발·테스트 환경 전용)
# 운영 시 반드시 제거하거나 false로 설정
# AUTH_BYPASS=true

# ── 브랜드 테마 ─────────────────────────────────────────────────────────────
BANK_BRAND=IBK

# ── git 자동 커밋 (운영 불필요 시 false 유지) ────────────────────────────────
GIT_AUTO_COMMIT=false
GIT_USER_NAME=Springware CMS
GIT_USER_EMAIL=cms@springware.local
GIT_BRANCH=main
